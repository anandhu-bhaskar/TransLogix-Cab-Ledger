# ── Database ──────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/
MONGODB_DB_NAME=translogix

# ── Session ────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace-with-at-least-64-random-characters

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS (production) ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# ALLOWED_ORIGINS=https://yourdomain.com

# ── Cloudinary (payment proof uploads) ────────────────────────────────────
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ── Google OAuth (optional) ───────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Add authorised redirect URI: http://localhost:3000/auth/google/callback
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
# In production, override the callback URL:
# GOOGLE_CALLBACK_URL=https://yourdomain.com/auth/google/callback
